{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "reflect-metadata"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "example"]
}
