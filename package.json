{
  "name": "@varbyte/nest-worker",
  "version": "0.1.3",
  "description": "NestJS-inspired micro framework for Cloudflare Workers with D1 support",
  "keywords": [
    "cloudflare",
    "workers",
    "nestjs",
    "d1",
    "framework",
    "decorators",
    "dependency-injection"
  ],
  "license": "MIT",
  "author": "Daniel Vargas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varbyte-dev/nest-worker"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.es.md",
    "EXAMPLES.md",
    "EXAMPLES.es.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "wrangler d1 execute my-app-db --file=./migrations/001_init.sql",
    "db:seed": "wrangler d1 execute my-app-db --file=./migrations/002_seed.sql"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "commit-and-tag-version": "^12.7.1",
    "typescript": "^5.3.3",
    "urlpattern-polyfill": "^10.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^3.40.0"
  },
  "peerDependencies": {
    "reflect-metadata": ">=0.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
